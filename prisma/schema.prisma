generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  RESTRICTED
  BANNED
  DELETED
}

enum Gender {
  MAN
  WOMAN
  NON_BINARY
  OTHER
}

enum InterestedIn {
  MEN
  WOMEN
  EVERYONE
  NON_BINARY
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ProfileVisibility {
  PUBLIC
  INCOGNITO
  HIDDEN
}

enum SubscriptionTier {
  FREE
  GOLD
  PLATINUM
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  TRIALING
}

enum PaymentProvider {
  STRIPE
  MOLLIE
}

enum PurchaseType {
  SPOTLIGHT
  BOOST
  SUPERLIKE_PACK
  VERIFICATION
  OTHER
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
}

enum LikeSource {
  GALLERY
  VIDEO
  SUPERLIKE
}

enum MatchSource {
  GALLERY
  VIDEO
  MANUAL
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
  CLOSED
}

enum MessageType {
  TEXT
  IMAGE
  GIF
  SYSTEM
}

enum ModerationStatus {
  CLEAN
  FLAGGED
  REMOVED
}

enum VideoQueueStatus {
  WAITING
  MATCHED
  CANCELED
  EXPIRED
}

enum VideoCallEndReason {
  NEXT
  DISCONNECT
  TIMEOUT
  REPORT
  MATCH
  ERROR
  LEFT_QUEUE
}

enum ReportContextType {
  PROFILE
  CHAT
  MESSAGE
  VIDEO
  USER
}

enum ReportReasonCode {
  SPAM
  FAKE_PROFILE
  UNDERAGE
  HARASSMENT
  NUDITY
  SCAM
  HATEFUL_BEHAVIOR
  OFF_PLATFORM_SOLICITATION
  OTHER
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ModerationActionType {
  WARNING
  RESTRICT
  BAN
  DELETE_MEDIA
  HIDE_PROFILE
  VERIFY_REJECT
  NONE
}

model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  passwordHash           String
  role                   UserRole            @default(USER)
  status                 UserStatus          @default(ACTIVE)
  emailVerifiedAt        DateTime?
  phoneNumber            String?
  phoneVerifiedAt        DateTime?
  trustScore             Int                 @default(100)
  lastSeenAt             DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  deletedAt              DateTime?

  profile                Profile?
  preferences            UserPreference?

  sentLikes              Like[]              @relation("SentLikes")
  receivedLikes          Like[]              @relation("ReceivedLikes")
  matchesA               Match[]             @relation("MatchUserA")
  matchesB               Match[]             @relation("MatchUserB")
  sentMessages           ChatMessage[]
  videoQueueSessions     VideoQueueSession[]
  videoCallsAsCaller     VideoCall[]         @relation("VideoCaller")
  videoCallsAsCallee     VideoCall[]         @relation("VideoCallee")
  subscriptions          Subscription[]
  purchases              Purchase[]
  entitlements           Entitlement[]
  reportsFiled           Report[]            @relation("ReportsFiled")
  reportsReceived        Report[]            @relation("ReportsReceived")
  blocksInitiated        Block[]             @relation("Blocker")
  blocksReceived         Block[]             @relation("Blocked")
  sessions               Session[]
  devices                DeviceFingerprint[]
  auditLogs              AuditLog[]          @relation("AuditActor")
  moderationActions      ModerationAction[]  @relation("ModeratorActions")
  dailyUsage             DailyUsage[]
  viewedProfiles         ProfileView[]       @relation("ViewerProfileViews")

  @@index([status])
  @@index([role])
  @@index([createdAt])
}

model Session {
  id             String    @id @default(cuid())
  userId         String
  refreshToken   String    @unique
  ipAddress      String?
  userAgent      String?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model DeviceFingerprint {
  id              String    @id @default(cuid())
  userId          String
  fingerprintHash String
  riskScore       Int       @default(0)
  ipAddress       String?
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fingerprintHash])
  @@index([riskScore])
}

model Profile {
  id                   String               @id @default(cuid())
  userId               String               @unique
  displayName          String               @db.VarChar(80)
  birthDate            DateTime
  gender               Gender
  interestedIn         InterestedIn
  bio                  String?              @db.Text
  city                 String?              @db.VarChar(100)
  region               String?              @db.VarChar(100)
  country              String?              @db.VarChar(2)
  lat                  Decimal?             @db.Decimal(9, 6)
  lng                  Decimal?             @db.Decimal(9, 6)
  avatarUrl            String?
  introVideoUrl        String?
  visibility           ProfileVisibility    @default(PUBLIC)
  verificationStatus   VerificationStatus   @default(UNVERIFIED)
  isVisible            Boolean              @default(true)
  isDiscoverable       Boolean              @default(true)
  onboardingCompleted  Boolean              @default(false)
  completionScore      Int                  @default(0)
  responseRate         Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  media                ProfileMedia[]
  spotlights           Spotlight[]
  profileViews         ProfileView[]
  reports              Report[]             @relation("ReportedProfile")

  @@index([isVisible, isDiscoverable])
  @@index([verificationStatus])
  @@index([city])
  @@index([country])
  @@index([completionScore])
  @@index([createdAt])
}

model ProfileMedia {
  id                 String             @id @default(cuid())
  profileId          String
  type               String             @db.VarChar(20)
  storageKey         String
  originalUrl        String?
  thumbUrl           String?
  sortOrder          Int                @default(0)
  width              Int?
  height             Int?
  durationSeconds    Int?
  moderationStatus   ModerationStatus   @default(CLEAN)
  createdAt          DateTime           @default(now())

  profile            Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, sortOrder])
  @@index([moderationStatus])
}

model UserPreference {
  id               String    @id @default(cuid())
  userId           String    @unique
  minAge           Int?
  maxAge           Int?
  maxDistanceKm    Int?
  showVerifiedOnly Boolean   @default(false)
  showOnlineOnly   Boolean   @default(false)
  allowMen         Boolean   @default(true)
  allowWomen       Boolean   @default(true)
  allowNonBinary   Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyUsage {
  id                 String    @id @default(cuid())
  userId             String
  dateKey            String
  profileViewsUsed   Int       @default(0)
  likesUsed          Int       @default(0)
  superLikesUsed     Int       @default(0)
  videoConnectsUsed  Int       @default(0)
  reportsFiledUsed   Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([dateKey])
}

model ProfileView {
  id               String    @id @default(cuid())
  viewerUserId     String
  viewedProfileId  String
  source           String?   @db.VarChar(20)
  createdAt        DateTime  @default(now())

  viewer           User      @relation("ViewerProfileViews", fields: [viewerUserId], references: [id], onDelete: Cascade)
  viewedProfile    Profile   @relation(fields: [viewedProfileId], references: [id], onDelete: Cascade)

  @@index([viewerUserId, createdAt])
  @@index([viewedProfileId, createdAt])
}

model Like {
  id          String      @id @default(cuid())
  fromUserId  String
  toUserId    String
  source      LikeSource  @default(GALLERY)
  createdAt   DateTime    @default(now())

  fromUser    User        @relation("SentLikes", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User        @relation("ReceivedLikes", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, createdAt])
  @@index([fromUserId, createdAt])
}

model Match {
  id          String      @id @default(cuid())
  userAId     String
  userBId     String
  source      MatchSource @default(GALLERY)
  createdAt   DateTime    @default(now())
  archivedAt  DateTime?

  userA       User        @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User        @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  chat        Chat?

  @@unique([userAId, userBId])
  @@index([userAId, createdAt])
  @@index([userBId, createdAt])
}

model Chat {
  id             String      @id @default(cuid())
  matchId        String      @unique
  status         ChatStatus  @default(ACTIVE)
  createdAt      DateTime    @default(now())
  lastMessageAt  DateTime?

  match          Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]

  @@index([status])
  @@index([lastMessageAt])
}

model ChatMessage {
  id                String             @id @default(cuid())
  chatId            String
  senderUserId      String
  type              MessageType        @default(TEXT)
  body              String?            @db.Text
  mediaUrl          String?
  moderationStatus  ModerationStatus   @default(CLEAN)
  createdAt         DateTime           @default(now())
  readAt            DateTime?

  chat              Chat               @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender            User               @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  reports           Report[]           @relation("ReportedMessage")

  @@index([chatId, createdAt])
  @@index([senderUserId, createdAt])
  @@index([moderationStatus])
}

model VideoQueueSession {
  id          String            @id @default(cuid())
  userId      String
  status      VideoQueueStatus  @default(WAITING)
  filtersJson Json?
  enteredAt   DateTime          @default(now())
  matchedAt   DateTime?
  expiredAt   DateTime?
  createdAt   DateTime          @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, enteredAt])
}

model VideoCall {
  id               String              @id @default(cuid())
  callerUserId     String
  calleeUserId     String
  signalingRoomKey String              @unique
  startedAt        DateTime            @default(now())
  endedAt          DateTime?
  endReason        VideoCallEndReason?
  mutualLike       Boolean             @default(false)
  callerLiked      Boolean             @default(false)
  calleeLiked      Boolean             @default(false)
  reportCount      Int                 @default(0)

  caller           User                @relation("VideoCaller", fields: [callerUserId], references: [id], onDelete: Cascade)
  callee           User                @relation("VideoCallee", fields: [calleeUserId], references: [id], onDelete: Cascade)
  reports          Report[]            @relation("ReportedVideo")

  @@index([callerUserId, startedAt])
  @@index([calleeUserId, startedAt])
  @@index([startedAt])
}

model Subscription {
  id                     String               @id @default(cuid())
  userId                 String
  provider               PaymentProvider
  providerCustomerId     String?
  providerSubscriptionId String?
  tier                   SubscriptionTier     @default(FREE)
  status                 SubscriptionStatus   @default(INACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([providerSubscriptionId])
}

model Purchase {
  id                String           @id @default(cuid())
  userId            String
  type              PurchaseType
  provider          PaymentProvider
  providerPaymentId String?
  amountCents       Int
  currency          String           @default("EUR")
  status            PurchaseStatus   @default(PENDING)
  metadataJson      Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([providerPaymentId])
  @@index([status])
}

model Entitlement {
  id          String    @id @default(cuid())
  userId      String
  featureCode String
  value       String?
  source      String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, featureCode])
  @@index([featureCode, endsAt])
}

model Spotlight {
  id         String    @id @default(cuid())
  profileId  String
  startsAt   DateTime
  endsAt     DateTime
  boostScore Int       @default(10)
  createdAt  DateTime  @default(now())

  profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, endsAt])
  @@index([startsAt, endsAt])
}

model Block {
  id             String    @id @default(cuid())
  blockerUserId  String
  blockedUserId  String
  createdAt      DateTime  @default(now())

  blocker        User      @relation("Blocker", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked        User      @relation("Blocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@index([blockedUserId])
}

model Report {
  id                  String             @id @default(cuid())
  reporterUserId      String
  reportedUserId      String?
  reportedProfileId   String?
  reportedMessageId   String?
  reportedVideoCallId String?
  contextType         ReportContextType
  reasonCode          ReportReasonCode
  notes               String?            @db.Text
  status              ReportStatus       @default(OPEN)
  createdAt           DateTime           @default(now())
  handledAt           DateTime?

  reporter            User               @relation("ReportsFiled", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reportedUser        User?              @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reportedProfile     Profile?           @relation("ReportedProfile", fields: [reportedProfileId], references: [id], onDelete: SetNull)
  reportedMessage     ChatMessage?       @relation("ReportedMessage", fields: [reportedMessageId], references: [id], onDelete: SetNull)
  reportedVideoCall   VideoCall?         @relation("ReportedVideo", fields: [reportedVideoCallId], references: [id], onDelete: SetNull)
  moderationActions   ModerationAction[]

  @@index([status, createdAt])
  @@index([reporterUserId, createdAt])
  @@index([reportedUserId, createdAt])
}

model ModerationAction {
  id               String                @id @default(cuid())
  reportId         String?
  moderatorUserId  String?
  targetUserId     String?
  actionType       ModerationActionType  @default(NONE)
  notes            String?               @db.Text
  createdAt        DateTime              @default(now())

  report           Report?               @relation(fields: [reportId], references: [id], onDelete: SetNull)
  moderator        User?                 @relation("ModeratorActions", fields: [moderatorUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt])
  @@index([actionType, createdAt])
}

model AuditLog {
  id           String    @id @default(cuid())
  actorUserId  String?
  action       String
  targetType   String?
  targetId     String?
  metadataJson Json?
  createdAt    DateTime  @default(now())

  actor        User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}
